{
  "name": "mykhanwrites",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "check": "astro check",
    "test": "vitest run",
    "verify:contrast": "node scripts/contrast-audit.mjs",
    "verify:links": "linkinator dist/ --recurse --skip \"[&]\" --skip \"https://.*\"",
    "verify:lh": "lhci autorun",
    "verify:a11y": "axe http://localhost:4321 http://localhost:4321/novel/ http://localhost:4321/about/ http://localhost:4321/writing/ http://localhost:4321/contact/ http://localhost:4321/letters/",
    "verify:a11y:screen": "echo 'Run: SCREEN_PUBLISHED=true npm run build && npm run preview, then: axe http://localhost:4321/screen/'"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource-variable/fraunces": "^5.0.0",
    "@fontsource/inter": "^5.0.0",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.2",
    "tailwindcss": "^4.3.1"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/cli": "^4.12.1",
    "@lhci/cli": "^0.15.1",
    "linkinator": "^7.6.1",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.7.2",
    "vitest": "^4.1.9"
  }
}
