---
/**
 * Card.astro
 *
 * Styleguide lock: `.card` selector in mockups/styleguide.html
 *
 * Flat, dark, defined by hairlines rather than shadows. Lifts and warms
 * border on hover.
 *
 * Rules:
 *   - NEVER pair the 1px border with a drop shadow (ghost-card tell).
 *   - No nested cards.
 *
 * Props:
 *   as — semantic element: 'article' | 'div' | 'li' (default: 'div')
 *   class — pass-through for additional classes
 */

const {
  as: Tag = 'div',
  class: className,
  ...rest
}: {
  as?: 'article' | 'div' | 'li';
  class?: string;
  [key: string]: unknown;
} = Astro.props;
---

<Tag class:list={['card', className]} {...rest}>
  <slot />
</Tag>

<style>
  .card {
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    padding: 30px;
    background: var(--color-ink-3);
    transition:
      transform var(--t) var(--ease-out),
      border-color var(--t);
  }

  .card:hover {
    border-color: rgba(201, 162, 75, .4);
    transform: translateY(-3px);
  }

  /* No drop shadow — the 1px border is the boundary. Ghost-card tells are banned. */
</style>
