---
/**
 * GhostButton.astro
 *
 * Styleguide lock: `.btn.btn-ghost` selector in mockups/styleguide.html
 *
 * Same shape as PrimaryButton but transparent background with amber text.
 * Use for secondary actions only — never as the primary CTA.
 *
 * Renders an <a> when `href` is provided; falls back to <button type="button">
 * (or type="submit" when `submit` prop is set).
 *
 * Pass-through: `class`, `aria-*`, `data-*` (Phase 10 adds data-umami-event).
 */

interface Props {
  href?: string;
  submit?: boolean;
  class?: string;
  [key: string]: unknown;
}

const { href, submit = false, class: className, ...rest } = Astro.props;

const tag = href ? 'a' : 'button';
const type = !href ? (submit ? 'submit' : 'button') : undefined;
---

{tag === 'a' ? (
  <a href={href} class:list={['btn', 'btn-ghost', className]} {...rest}>
    <slot />
  </a>
) : (
  <button type={type} class:list={['btn', 'btn-ghost', className]} {...rest}>
    <slot />
  </button>
)}

<style>
  .btn {
    display: inline-block;
    padding: .95em 1.8em;
    border-radius: var(--radius-sm);
    font-size: .82rem;
    letter-spacing: .13em;
    text-transform: uppercase;
    font-weight: 500;
    border: 1px solid var(--color-amber);
    transition:
      transform var(--t) var(--ease-out),
      background var(--t);
    text-decoration: none;
    cursor: pointer;
    font-family: var(--font-sans);
    line-height: 1;
  }

  .btn-ghost {
    background: transparent;
    color: var(--color-amber);
  }

  .btn-ghost:hover {
    background: rgba(201, 162, 75, .1);
    color: var(--color-amber-bright);
    transform: translateY(-2px);
  }

  /* Focus-visible ring is inherited from global.css *:focus-visible rule */
</style>
