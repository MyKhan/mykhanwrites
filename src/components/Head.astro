---
/**
 * Head.astro — <head> contents for every page
 *
 * Emits: charset, viewport, title, meta description, canonical <link>,
 * font preload <link>, favicon <link>, OG + Twitter share meta, optional
 * noindex, and a <slot/> for per-page extra head tags (JSON-LD, etc.).
 *
 * Font preload (Phase 2 handoff, T13):
 *   Imports frauncesRomanLatinUrl from ../lib/fonts and emits exactly one
 *   <link rel="preload" as="font" type="font/woff2" crossorigin href={...}>
 *   for the critical Fraunces roman latin variable font.
 *   Only the roman (upright) face — do NOT preload italic (not render-blocking).
 *
 * Share meta (full seo.ts integration — Phase 11):
 *   og:title, og:description, og:type (website), og:url (= canonical, www-correct),
 *   og:image, og:image:width/height (1200/630), twitter:card, twitter:image.
 *   When ogImage is omitted the OG stub placeholder is used as default.
 *
 * Canonical (Phase 11):
 *   <link rel="canonical" href={canonicalUrl}> derived from Astro.site + pathname.
 *
 * noindex (M1 prelaunch belt-and-suspenders):
 *   When noindex=true, emits <meta name="robots" content="noindex,nofollow">.
 *   At launch (PRELAUNCH=false) the noindex prop is omitted → tag absent.
 *
 * Props:
 *   title       — <title> text (required)
 *   description — meta description (required)
 *   ogImage     — OG image URL; defaults to /og/placeholder-1200x630.png
 *   noindex     — when true, emits noindex,nofollow robots meta (default: false)
 */

import { frauncesRomanLatinUrl } from '../lib/fonts';
import { buildSeoMeta, OG_IMAGE_WIDTH, OG_IMAGE_HEIGHT } from '../lib/seo';
import { SITE_ORIGIN } from '../lib/siteOrigin';
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  noindex?: boolean;
}

const { title, description, ogImage, noindex = false } = Astro.props;

// Derive site origin from Astro.site (astro.config.mjs); SITE_ORIGIN is the shared fallback.
const siteOrigin = Astro.site ? Astro.site.origin : SITE_ORIGIN;

const seo = buildSeoMeta({
  title,
  description,
  pathname: Astro.url.pathname,
  siteOrigin,
  ogImage,
});
---

<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{seo.title}</title>
<meta name="description" content={seo.description} />

<!-- Canonical URL (Phase 11) -->
<link rel="canonical" href={seo.canonicalUrl} />

<!-- Prelaunch noindex (belt-and-suspenders with M1b robots.txt) -->
{noindex && <meta name="robots" content="noindex,nofollow" />}

<!-- Critical font preload: Fraunces roman latin variable subset (Phase 2 handoff T13) -->
<link rel="preload" as="font" type="font/woff2" crossorigin href={frauncesRomanLatinUrl} />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />

<!-- Open Graph share meta -->
<meta property="og:title" content={seo.title} />
<meta property="og:description" content={seo.description} />
<meta property="og:type" content="website" />
<meta property="og:url" content={seo.canonicalUrl} />
<meta property="og:image" content={seo.absoluteOgImage} />
<meta property="og:image:width" content={OG_IMAGE_WIDTH} />
<meta property="og:image:height" content={OG_IMAGE_HEIGHT} />

<!-- Twitter / X card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:image" content={seo.absoluteOgImage} />

<!-- Per-page extra head tags (JSON-LD, etc.) -->
<slot />
