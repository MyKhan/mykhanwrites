---
/**
 * index.astro — Homepage (Phase 6a: Hero + LettersForm)
 *
 * Renders the locked Hero and Kit-wired LettersForm for M1 verification.
 * Full homepage IA (NovelBridge, AboutPreview, WritingRange) comes in Phase 6b.
 * BaseLayout wiring (Header/Footer/Grain/ClientRouter) stays intact.
 */

import { getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import LettersForm from '../components/LettersForm.astro';
import Section from '../components/Section.astro';

const homePage = await getEntry('pages', 'home');
const { title, description } = homePage.data;
---

<BaseLayout title={title} description={description}>
  <Hero />
  <Section>
    <LettersForm variant="full" />
  </Section>
</BaseLayout>
