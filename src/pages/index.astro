---
/**
 * index.astro — Homepage
 *
 * Branches on the PRELAUNCH build flag:
 *
 *   PRELAUNCH === true  (default, safe pre-launch state)
 *     → <BaseLayout minimal noindex> wrapping <ComingSoon />
 *       • minimal chrome: wordmark-only header, identity-only footer
 *       • noindex: emits <meta name="robots" content="noindex,nofollow">
 *       • ComingSoon: Hero + LettersForm (full variant) + "full site on its way" note
 *
 *   PRELAUNCH === false (set explicitly at build time for the live site)
 *     → Full homepage (assembled in Phase 6b).
 *       Stand-in here so PRELAUNCH=false builds compile cleanly.
 *       Phase 6b replaces the stand-in with the full IA.
 */

import { getEntry } from 'astro:content';
import { PRELAUNCH } from '../lib/flags';
import BaseLayout from '../layouts/BaseLayout.astro';
import ComingSoon from '../components/ComingSoon.astro';
import Hero from '../components/Hero.astro';
import NovelBridge from '../components/NovelBridge.astro';
import LettersForm from '../components/LettersForm.astro';
import AboutPreview from '../components/AboutPreview.astro';
import WritingRange from '../components/WritingRange.astro';
import Section from '../components/Section.astro';

const homePage = await getEntry('pages', 'home');
const { title, description } = homePage.data;

// OG image for the coming-soon share surface
const OG_IMAGE = '/og/placeholder-1200x630.png';
---

{PRELAUNCH ? (
  <BaseLayout
    title={title}
    description={description}
    ogImage={OG_IMAGE}
    minimal
    noindex
    showFooterSignup={false}
  >
    <ComingSoon />
  </BaseLayout>
) : (
  <BaseLayout title={title} description={description} ogImage={OG_IMAGE}>
    {/*
      Full homepage IA — LOCKED ORDER (R6 — do not reorder):
        Header (from BaseLayout chrome)
        Hero
        NovelBridge
        LettersForm (full variant, mid-page — peak-interest placement)
        AboutPreview
        WritingRange
        Footer (from BaseLayout chrome, compact signup included)
    */}
    <Hero />
    <NovelBridge />
    <Section>
      <LettersForm variant="full" />
    </Section>
    <AboutPreview />
    <WritingRange />
  </BaseLayout>
)}
