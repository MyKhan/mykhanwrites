---
/**
 * 404.astro — Not Found page
 *
 * Astro emits this as /404.html (flat file, not a directory) even in
 * format:'directory' mode. This matches the .htaccess ErrorDocument directive:
 *   ErrorDocument 404 /404.html
 *
 * Uses BaseLayout with full chrome so visitors can find their way back.
 * noindex: true — search engines must not index error pages.
 *
 * site.states.notFound404 is split: .message + .linkLabel
 * "Head back home →" appears EXACTLY ONCE — as the link text.
 */

import BaseLayout from '../layouts/BaseLayout.astro';
import { site } from '../lib/data';
---

<BaseLayout
  title="Page not found — MyKhanWrites"
  description="The page you were looking for doesn't exist."
  noindex
>
  <section class="not-found">
    <p class="not-found__message">{site.states.notFound404.message}</p>
    <a href="/" class="not-found__link">{site.states.notFound404.linkLabel}</a>
  </section>
</BaseLayout>

<style>
  .not-found {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    min-height: 40vh;
    padding: 4rem 1.5rem;
    text-align: center;
    gap: 1.5rem;
  }

  .not-found__message {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2.5vw, 1.6rem);
    line-height: 1.5;
    color: var(--color-parchment);
    max-width: 36ch;
    margin: 0;
  }

  .not-found__link {
    font-size: 0.9rem;
    color: var(--color-parchment);
    border-bottom: 1px solid var(--line);
    padding-bottom: 3px;
    text-decoration: none;
    transition:
      color var(--t),
      border-color var(--t);
  }

  .not-found__link:hover {
    color: var(--color-amber);
    border-color: var(--color-amber);
  }

  .not-found__link:focus-visible {
    outline: 2px solid var(--color-amber);
    outline-offset: 3px;
  }
</style>
