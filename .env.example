# ============================================================
# mykhanwrites.com — Environment variables reference
# Copy to .env and fill in values. Never commit .env.
# ============================================================

# ---- Kit (ConvertKit) -----------------------------------------------
# Hosted-form ID: goes into the form action URL as public static HTML.
# The signup posts directly to Kit's hosted form endpoint, so NO Kit
# secret API key is needed — KIT_API_KEY is deliberately absent.
PUBLIC_KIT_FORM_ID=

# ---- Web3Forms ------------------------------------------------------
# Access key for the contact form. This is PUBLIC build config placed
# in a hidden form field (not a secret). Keep it here, not in a vault.
PUBLIC_WEB3FORMS_ACCESS_KEY=

# ---- Umami Analytics ------------------------------------------------
# Umami Cloud website ID (public tracking snippet value).
PUBLIC_UMAMI_ID=

# ---- Build flags ----------------------------------------------------
# PRELAUNCH and SCREEN_PUBLISHED now live in SETTINGS.md at the project root —
# edit the true/false values there, no code needed. Do NOT set them here: a
# value in .env would override SETTINGS.md and cause confusion.
#
# (Advanced: setting them as one-off env vars on the build command still works,
#  e.g. `PRELAUNCH=false npm run build`, for CI / launch-flip automation.)

# ---- Apache / Hostinger auth (NOT committed) -----------------------
# The .htpasswd file used for HTTP basic auth on the staging environment
# lives ABOVE the public_html directory on the server and is NEVER
# committed to this repo. Manage it via Hostinger's file manager or SSH.
